// BSLLS-off
#Использовать 1commands

// Сборка .NET компоненты если DLL отсутствует
КаталогПроекта = Новый Файл(ТекущийСценарий().Каталог + "/..").ПолноеИмя;
ПутьКDLL = ОбъединитьПути(КаталогПроекта, "Components", "dotnet", "1script_change_indexer.dll");

Если НЕ Новый Файл(ПутьКDLL).Существует() Тогда
    Сообщить("DLL не найдена, выполняю сборку .NET компоненты...");
    
    ФайлПроекта = ОбъединитьПути(КаталогПроекта, "src", "change_indexer.csproj");
    КаталогВывода = ОбъединитьПути(КаталогПроекта, "Components", "dotnet");
    
    КомандаСборки = Новый Команда;
    КомандаСборки.УстановитьКоманду("dotnet");
    КомандаСборки.ДобавитьПараметр("build");
    КомандаСборки.ДобавитьПараметр("""" + ФайлПроекта + """");
    КомандаСборки.ДобавитьПараметр("-c Release");
    КомандаСборки.ДобавитьПараметр("-o """ + КаталогВывода + """");
    КомандаСборки.ПоказыватьВыводНемедленно(Истина);
    
    КодСборки = КомандаСборки.Исполнить();
    Если КодСборки <> 0 Тогда
        ВызватьИсключение "Сборка .NET компоненты завершилась с ошибкой! Код возврата: " + КодСборки;
    КонецЕсли;
КонецЕсли;

ПутьКОтчетуJUnit = ОбъединитьПути(".", "build", "reports", "junit.xml");
КаталогОтчетов = ОбъединитьПути(".", "build", "reports");
Файл = Новый Файл(КаталогОтчетов);
Если Не Файл.Существует() Тогда
    СоздатьКаталог(КаталогОтчетов);
КонецЕсли;

Команда = Новый Команда;
Команда.УстановитьКоманду("oneunit");
Команда.ДобавитьПараметр("execute");
Команда.ДобавитьПараметр("-d tests");
Команда.ДобавитьПараметр("-r");
Команда.ДобавитьПараметр("--junit " + ПутьКОтчетуJUnit);
Команда.ПоказыватьВыводНемедленно(Истина);

КодВозврата = Команда.Исполнить();

Если КодВозврата <> 0 Тогда
    ВызватьИсключение "Тестирование завершилось неудачно!";
КонецЕсли;
