// BSLLS-off
// Тестовый набор: РезультатСравнения
// Юнит-тесты для класса РезультатСравнения.

#Использовать asserts
#Использовать ".."

&Тест
Процедура ТестДолжен_СоздатьПустойРезультат() Экспорт
    // Дано
    Результат = Новый РезультатСравнения;

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения()).ЭтоЛожь();
    Ожидаем.Что(Результат.КоличествоИзменений()).Равно(0);
    Ожидаем.Что(Результат.Добавленные().Количество()).Равно(0);
    Ожидаем.Что(Результат.Удаленные().Количество()).Равно(0);
    Ожидаем.Что(Результат.Измененные().Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура ТестДолжен_ДобавитьДобавленный() Экспорт
    // Дано
    Результат = Новый РезультатСравнения;

    // Когда
    Результат.ДобавитьДобавленный("file1.txt");
    Результат.ДобавитьДобавленный("file2.txt");

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения()).ЭтоИстина();
    Ожидаем.Что(Результат.КоличествоИзменений()).Равно(2);
    Ожидаем.Что(Результат.Добавленные().Количество()).Равно(2);
    Ожидаем.Что(Результат.Добавленные()[0]).Равно("file1.txt");
    Ожидаем.Что(Результат.Добавленные()[1]).Равно("file2.txt");
КонецПроцедуры

&Тест
Процедура ТестДолжен_ДобавитьУдаленный() Экспорт
    // Дано
    Результат = Новый РезультатСравнения;

    // Когда
    Результат.ДобавитьУдаленный("old_file.txt");

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения()).ЭтоИстина();
    Ожидаем.Что(Результат.Удаленные().Количество()).Равно(1);
    Ожидаем.Что(Результат.Удаленные()[0]).Равно("old_file.txt");
КонецПроцедуры

&Тест
Процедура ТестДолжен_ДобавитьИзмененный() Экспорт
    // Дано
    Результат = Новый РезультатСравнения;

    // Когда
    Результат.ДобавитьИзмененный("modified.txt");

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения()).ЭтоИстина();
    Ожидаем.Что(Результат.Измененные().Количество()).Равно(1);
    Ожидаем.Что(Результат.Измененные()[0]).Равно("modified.txt");
КонецПроцедуры

&Тест
Процедура ТестДолжен_ПравильноСчитатьОбщееКоличество() Экспорт
    // Дано
    Результат = Новый РезультатСравнения;

    // Когда
    Результат.ДобавитьДобавленный("new1.txt");
    Результат.ДобавитьДобавленный("new2.txt");
    Результат.ДобавитьУдаленный("old1.txt");
    Результат.ДобавитьИзмененный("mod1.txt");
    Результат.ДобавитьИзмененный("mod2.txt");
    Результат.ДобавитьИзмененный("mod3.txt");

    // Тогда
    Ожидаем.Что(Результат.КоличествоИзменений()).Равно(6);
    Ожидаем.Что(Результат.Добавленные().Количество()).Равно(2);
    Ожидаем.Что(Результат.Удаленные().Количество()).Равно(1);
    Ожидаем.Что(Результат.Измененные().Количество()).Равно(3);
КонецПроцедуры
