// BSLLS-off
// Тестовый набор: МенеджерИндексов
// Юнит-тесты для высокоуровневого фасада МенеджерИндексов.

#Использовать asserts
#Использовать ".."

Перем КаталогТестовыхДанных;     // Строка
Перем мКаталогВрем;    // Строка
Перем ВременныеФайлы;            // Массив путей для очистки

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередВсеми
Процедура ИнициализироватьВсе() Экспорт
    мКаталогВрем = ОбъединитьПути(КаталогВременныхФайлов(), "change_indexer_mgr_tests");
    СоздатьКаталог(мКаталогВрем);
    ВременныеФайлы = Новый Массив;

    // Создаём тестовый каталог с файлами
    КаталогТестовыхДанных = ОбъединитьПути(мКаталогВрем, "test_data");
    СоздатьКаталог(КаталогТестовыхДанных);
    ВременныеФайлы.Добавить(КаталогТестовыхДанных);

    Запись = Новый ЗаписьТекста(ОбъединитьПути(КаталогТестовыхДанных, "file1.txt"), "UTF-8");
    Запись.ЗаписатьСтроку("content1");
    Запись.Закрыть();

    Запись = Новый ЗаписьТекста(ОбъединитьПути(КаталогТестовыхДанных, "file2.txt"), "UTF-8");
    Запись.ЗаписатьСтроку("content2");
    Запись.Закрыть();
КонецПроцедуры

&ПослеВсех
Процедура ЗавершениеВсех() Экспорт
    Для Каждого Путь Из ВременныеФайлы Цикл
        Попытка
            УдалитьФайлы(Путь);
        Исключение
        КонецПопытки;
    КонецЦикла;
    Попытка
        УдалитьФайлы(мКаталогВрем);
    Исключение
    КонецПопытки;
КонецПроцедуры

&Тест
Процедура ТестДолжен_ОпределитьОтсутствиеИндекса() Экспорт
    // Дано
    ПутьКИндексу = ОбъединитьПути(мКаталогВрем, "not_exist.cidx");
    Менеджер = Новый МенеджерИндексов(КаталогТестовыхДанных, ПутьКИндексу);

    // Тогда
    Ожидаем.Что(Менеджер.СуществуетИндекс()).ЭтоЛожь();
КонецПроцедуры

&Тест
Процедура ТестДолжен_ПерестроитьИндексИНайтиЕго() Экспорт
    // Дано
    ПутьКИндексу = ОбъединитьПути(мКаталогВрем, "rebuild_test.cidx");
    ВременныеФайлы.Добавить(ПутьКИндексу);
    Менеджер = Новый МенеджерИндексов(КаталогТестовыхДанных, ПутьКИндексу);

    // Когда
    Менеджер.Перестроить();

    // Тогда
    Ожидаем.Что(Менеджер.СуществуетИндекс(), "Индекс должен быть создан").ЭтоИстина();
КонецПроцедуры

&Тест
Процедура ТестДолжен_ВернутьВсеФайлыКакДобавленныеБезИндекса() Экспорт
    // Дано
    ПутьКИндексу = ОбъединитьПути(мКаталогВрем, "no_prev_index.cidx");
    Менеджер = Новый МенеджерИндексов(КаталогТестовыхДанных, ПутьКИндексу);

    // Когда
    Результат = Менеджер.ПолучитьИзменения();

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения(), "Должны быть изменения").ЭтоИстина();
    Ожидаем.Что(Результат.Добавленные().Количество(), "Все файлы добавлены").БольшеИлиРавно(1);
    Ожидаем.Что(Результат.Удаленные().Количество()).Равно(0);
    Ожидаем.Что(Результат.Измененные().Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура ТестДолжен_НеНайтиИзмененийПослеПерестроения() Экспорт
    // Дано
    ПутьКИндексу = ОбъединитьПути(мКаталогВрем, "no_changes.cidx");
    ВременныеФайлы.Добавить(ПутьКИндексу);
    Менеджер = Новый МенеджерИндексов(КаталогТестовыхДанных, ПутьКИндексу);
    Менеджер.Перестроить();

    // Когда
    Результат = Менеджер.ПолучитьИзменения();

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения(), "Не должно быть изменений").ЭтоЛожь();
КонецПроцедуры

&Тест
Процедура ТестДолжен_ОбнаружитьИзмененияВоВременномКаталоге() Экспорт
    // Дано — создаём каталог, строим индекс, добавляем файл, проверяем
    ВремКаталог = ОбъединитьПути(мКаталогВрем, "mgr_changes");
    СоздатьКаталог(ВремКаталог);
    ВременныеФайлы.Добавить(ВремКаталог);

    ПутьКФайлу = ОбъединитьПути(ВремКаталог, "original.txt");
    Запись = Новый ЗаписьТекста(ПутьКФайлу, "UTF-8");
    Запись.ЗаписатьСтроку("оригинал");
    Запись.Закрыть();

    ПутьКИндексу = ОбъединитьПути(мКаталогВрем, "mgr_changes.cidx");
    ВременныеФайлы.Добавить(ПутьКИндексу);

    Менеджер = Новый МенеджерИндексов(ВремКаталог, ПутьКИндексу);
    Менеджер.Перестроить();

    // Когда — добавляем новый файл
    НовыйПуть = ОбъединитьПути(ВремКаталог, "new_file.txt");
    Запись = Новый ЗаписьТекста(НовыйПуть, "UTF-8");
    Запись.ЗаписатьСтроку("новый файл");
    Запись.Закрыть();

    Результат = Менеджер.ПолучитьИзменения();

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения()).ЭтоИстина();
    Ожидаем.Что(Результат.Добавленные().Количество()).Равно(1);
    Ожидаем.Что(Результат.Добавленные()[0]).Содержит("new_file.txt");
КонецПроцедуры

&Тест
Процедура ТестДолжен_УдалитьИндекс() Экспорт
    // Дано
    ПутьКИндексу = ОбъединитьПути(мКаталогВрем, "delete_test.cidx");
    ВременныеФайлы.Добавить(ПутьКИндексу);
    Менеджер = Новый МенеджерИндексов(КаталогТестовыхДанных, ПутьКИндексу);
    Менеджер.Перестроить();
    Ожидаем.Что(Менеджер.СуществуетИндекс()).ЭтоИстина();

    // Когда
    Менеджер.УдалитьИндекс();

    // Тогда
    Ожидаем.Что(Менеджер.СуществуетИндекс()).ЭтоЛожь();
КонецПроцедуры

&Тест
Процедура ТестДолжен_ПолучитьТекущийИндексБезСохранения() Экспорт
    // Дано
    ПутьКИндексу = ОбъединитьПути(мКаталогВрем, "no_save.cidx");
    Менеджер = Новый МенеджерИндексов(КаталогТестовыхДанных, ПутьКИндексу);

    // Когда
    Индекс = Менеджер.ПолучитьТекущийИндекс();

    // Тогда
    Ожидаем.Что(Индекс.Количество()).БольшеИлиРавно(1);
    Ожидаем.Что(Менеджер.СуществуетИндекс(), "Индекс не должен быть сохранён на диск").ЭтоЛожь();
КонецПроцедуры

&Тест
Процедура ТестДолжен_ПрименятьИсключенияЧерезМенеджер() Экспорт
    // Дано
    ВремКаталог = ОбъединитьПути(мКаталогВрем, "mgr_exclude");
    СоздатьКаталог(ВремКаталог);
    ВременныеФайлы.Добавить(ВремКаталог);

    Запись = Новый ЗаписьТекста(ОбъединитьПути(ВремКаталог, "good.txt"), "UTF-8");
    Запись.ЗаписатьСтроку("хороший");
    Запись.Закрыть();

    Запись = Новый ЗаписьТекста(ОбъединитьПути(ВремКаталог, "bad.tmp"), "UTF-8");
    Запись.ЗаписатьСтроку("плохой");
    Запись.Закрыть();

    ПутьКИндексу = ОбъединитьПути(мКаталогВрем, "mgr_exclude.cidx");
    ВременныеФайлы.Добавить(ПутьКИндексу);

    Менеджер = Новый МенеджерИндексов(ВремКаталог, ПутьКИндексу);
    Менеджер.ДобавитьИсключение(".tmp");

    // Когда
    Индекс = Менеджер.ПолучитьТекущийИндекс();

    // Тогда
    Ожидаем.Что(Индекс.Количество()).Равно(1);
КонецПроцедуры

&Тест
Процедура ТестДолжен_ВернутьКорректныеСвойства() Экспорт
    // Дано
    ПутьКИндексу = ОбъединитьПути(мКаталогВрем, "props.cidx");
    Менеджер = Новый МенеджерИндексов(КаталогТестовыхДанных, ПутьКИндексу);

    // Тогда
    Ожидаем.Что(Менеджер.ПолучитьКаталогНаблюдения()).Равно(КаталогТестовыхДанных);
    Ожидаем.Что(Менеджер.ПолучитьПутьКИндексу()).Равно(ПутьКИндексу);
КонецПроцедуры
