// BSLLS-off
// Тестовый набор: ИндексКаталога
// Юнит-тесты для класса ИндексКаталога — построение, сохранение, загрузка, сравнение.

#Использовать asserts
#Использовать ".."

Перем КаталогТестовыхДанных;     // Строка
Перем мКаталогВрем;              // Строка
Перем ВременныеФайлы;            // Массив путей для очистки

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередВсеми
Процедура ИнициализироватьВсе() Экспорт
    мКаталогВрем = ОбъединитьПути(КаталогВременныхФайлов(), "change_indexer_tests");
    СоздатьКаталог(мКаталогВрем);
    ВременныеФайлы = Новый Массив;

    // Создаём тестовый каталог с файлами
    КаталогТестовыхДанных = ОбъединитьПути(мКаталогВрем, "test_data");
    СоздатьКаталог(КаталогТестовыхДанных);
    ВременныеФайлы.Добавить(КаталогТестовыхДанных);

    ПодКаталог = ОбъединитьПути(КаталогТестовыхДанных, "subdir");
    СоздатьКаталог(ПодКаталог);

    Запись = Новый ЗаписьТекста(ОбъединитьПути(КаталогТестовыхДанных, "Configuration.xml"), "UTF-8");
    Запись.ЗаписатьСтроку("<Configuration/>");
    Запись.Закрыть();

    Запись = Новый ЗаписьТекста(ОбъединитьПути(КаталогТестовыхДанных, "file1.txt"), "UTF-8");
    Запись.ЗаписатьСтроку("content1");
    Запись.Закрыть();

    Запись = Новый ЗаписьТекста(ОбъединитьПути(ПодКаталог, "file2.txt"), "UTF-8");
    Запись.ЗаписатьСтроку("content2");
    Запись.Закрыть();
КонецПроцедуры

&ПослеВсех
Процедура ЗавершениеВсех() Экспорт
    Для Каждого Путь Из ВременныеФайлы Цикл
        Попытка
            УдалитьФайлы(Путь);
        Исключение
        КонецПопытки;
    КонецЦикла;
    Попытка
        УдалитьФайлы(мКаталогВрем);
    Исключение
    КонецПопытки;
КонецПроцедуры

&Тест
Процедура ТестДолжен_ПостроитьИндексПоКаталогу() Экспорт
    // Дано
    Индекс = Новый ИндексКаталога;

    // Когда
    Индекс.ПостроитьПоКаталогу(КаталогТестовыхДанных);

    // Тогда
    Ожидаем.Что(Индекс.Количество(), "Количество записей должно быть > 0").БольшеИлиРавно(1);
    Ожидаем.Что(Индекс.ПолучитьКорневойКаталог(), "Корневой каталог должен быть заполнен").Заполнено();
КонецПроцедуры

&Тест
Процедура ТестДолжен_СодержатьConfigurationXml() Экспорт
    // Дано
    Индекс = Новый ИндексКаталога;
    Индекс.ПостроитьПоКаталогу(КаталогТестовыхДанных);

    // Когда
    Записи = Индекс.ПолучитьЗаписи();

    // Тогда
    НашелConfiguration = Ложь;
    Для Каждого Запись Из Записи Цикл
        Если СтрНайти(Запись, "Configuration.xml") > 0 Тогда
            НашелConfiguration = Истина;
            Прервать;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НашелConfiguration, "В индексе должен быть Configuration.xml").ЭтоИстина();
КонецПроцедуры

&Тест
Процедура ТестДолжен_СохранитьИЗагрузитьИндекс() Экспорт
    // Дано
    Индекс = Новый ИндексКаталога;
    Индекс.ПостроитьПоКаталогу(КаталогТестовыхДанных);
    ПутьКФайлу = ОбъединитьПути(мКаталогВрем, "test_save_load.cidx");
    ВременныеФайлы.Добавить(ПутьКФайлу);

    // Когда
    Индекс.Сохранить(ПутьКФайлу);

    ЗагруженныйИндекс = Новый ИндексКаталога;
    ЗагруженныйИндекс.Загрузить(ПутьКФайлу);

    // Тогда
    Ожидаем.Что(ЗагруженныйИндекс.Количество(), "Количество записей должно совпасть")
        .Равно(Индекс.Количество());

    ИсходныеЗаписи = Индекс.ПолучитьЗаписи();
    ЗагруженныеЗаписи = ЗагруженныйИндекс.ПолучитьЗаписи();
    Для Сч = 0 По ИсходныеЗаписи.Количество() - 1 Цикл
        Ожидаем.Что(ЗагруженныеЗаписи[Сч]).Равно(ИсходныеЗаписи[Сч]);
    КонецЦикла;
КонецПроцедуры

&Тест
Процедура ТестДолжен_ОбнаружитьОтсутствиеИзмененийПриСравненииСамСебя() Экспорт
    // Дано
    Индекс1 = Новый ИндексКаталога;
    Индекс1.ПостроитьПоКаталогу(КаталогТестовыхДанных);

    Индекс2 = Новый ИндексКаталога;
    Индекс2.ПостроитьПоКаталогу(КаталогТестовыхДанных);

    // Когда
    Результат = Индекс2.ПолучитьИзменения(Индекс1);

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения(), "При сравнении с собой не должно быть изменений").ЭтоЛожь();
    Ожидаем.Что(Результат.КоличествоИзменений()).Равно(0);
КонецПроцедуры

&Тест
Процедура ТестДолжен_ОбнаружитьДобавленныеФайлы() Экспорт
    // Дано — старый индекс пустой, новый — реальный
    СтарыйИндекс = Новый ИндексКаталога;

    НовыйИндекс = Новый ИндексКаталога;
    НовыйИндекс.ПостроитьПоКаталогу(КаталогТестовыхДанных);

    // Когда
    Результат = НовыйИндекс.ПолучитьИзменения(СтарыйИндекс);

    // Тогда
    Ожидаем.Что(Результат.Добавленные().Количество(), "Все файлы должны быть добавленными")
        .Равно(НовыйИндекс.Количество());
    Ожидаем.Что(Результат.Удаленные().Количество()).Равно(0);
    Ожидаем.Что(Результат.Измененные().Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура ТестДолжен_ОбнаружитьУдаленныеФайлы() Экспорт
    // Дано — старый индекс реальный, новый — пустой
    СтарыйИндекс = Новый ИндексКаталога;
    СтарыйИндекс.ПостроитьПоКаталогу(КаталогТестовыхДанных);

    НовыйИндекс = Новый ИндексКаталога;

    // Когда
    Результат = НовыйИндекс.ПолучитьИзменения(СтарыйИндекс);

    // Тогда
    Ожидаем.Что(Результат.Удаленные().Количество(), "Все файлы должны быть удалёнными")
        .Равно(СтарыйИндекс.Количество());
    Ожидаем.Что(Результат.Добавленные().Количество()).Равно(0);
    Ожидаем.Что(Результат.Измененные().Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура ТестДолжен_ОбнаружитьИзмененныйФайл() Экспорт
    // Дано — строим индекс, сохраняем, модифицируем файл, строим снова
    ВремКаталог = ОбъединитьПути(мКаталогВрем, "test_modified");
    СоздатьКаталог(ВремКаталог);
    ВременныеФайлы.Добавить(ВремКаталог);

    ПутьКФайлу = ОбъединитьПути(ВремКаталог, "test.txt");
    ЗаписьТекстаФайла = Новый ЗаписьТекста(ПутьКФайлу, "UTF-8");
    ЗаписьТекстаФайла.ЗаписатьСтроку("начальное содержимое");
    ЗаписьТекстаФайла.Закрыть();

    Индекс1 = Новый ИндексКаталога;
    Индекс1.ПостроитьПоКаталогу(ВремКаталог);

    // Когда — изменяем файл (другой размер)
    ЗаписьТекстаФайла = Новый ЗаписьТекста(ПутьКФайлу, "UTF-8");
    ЗаписьТекстаФайла.ЗаписатьСтроку("изменённое содержимое, которое длиннее первоначального");
    ЗаписьТекстаФайла.Закрыть();

    Индекс2 = Новый ИндексКаталога;
    Индекс2.ПостроитьПоКаталогу(ВремКаталог);

    Результат = Индекс2.ПолучитьИзменения(Индекс1);

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения(), "Должны быть изменения").ЭтоИстина();
    Ожидаем.Что(Результат.Измененные().Количество(), "Один файл изменён").Равно(1);
    Ожидаем.Что(Результат.Измененные()[0]).Содержит("test.txt");
КонецПроцедуры

&Тест
Процедура ТестДолжен_ОбнаружитьДобавленныйИУдаленныйФайл() Экспорт
    // Дано
    ВремКаталог = ОбъединитьПути(мКаталогВрем, "test_add_del");
    СоздатьКаталог(ВремКаталог);
    ВременныеФайлы.Добавить(ВремКаталог);

    ПутьФайл1 = ОбъединитьПути(ВремКаталог, "file_a.txt");
    ЗаписьТекстаФайла = Новый ЗаписьТекста(ПутьФайл1, "UTF-8");
    ЗаписьТекстаФайла.ЗаписатьСтроку("файл A");
    ЗаписьТекстаФайла.Закрыть();

    Индекс1 = Новый ИндексКаталога;
    Индекс1.ПостроитьПоКаталогу(ВремКаталог);

    // Когда — удаляем файл A, добавляем файл B
    УдалитьФайлы(ПутьФайл1);

    ПутьФайл2 = ОбъединитьПути(ВремКаталог, "file_b.txt");
    ЗаписьТекстаФайла = Новый ЗаписьТекста(ПутьФайл2, "UTF-8");
    ЗаписьТекстаФайла.ЗаписатьСтроку("файл B");
    ЗаписьТекстаФайла.Закрыть();

    Индекс2 = Новый ИндексКаталога;
    Индекс2.ПостроитьПоКаталогу(ВремКаталог);

    Результат = Индекс2.ПолучитьИзменения(Индекс1);

    // Тогда
    Ожидаем.Что(Результат.ЕстьИзменения()).ЭтоИстина();
    Ожидаем.Что(Результат.Добавленные().Количество(), "Один файл добавлен").Равно(1);
    Ожидаем.Что(Результат.Удаленные().Количество(), "Один файл удалён").Равно(1);
    Ожидаем.Что(Результат.Добавленные()[0]).Содержит("file_b.txt");
    Ожидаем.Что(Результат.Удаленные()[0]).Содержит("file_a.txt");
КонецПроцедуры

&Тест
Процедура ТестДолжен_ИсключатьФайлыПоМаске() Экспорт
    // Дано
    ВремКаталог = ОбъединитьПути(мКаталогВрем, "test_exclude");
    СоздатьКаталог(ВремКаталог);
    ВременныеФайлы.Добавить(ВремКаталог);

    ПутьФайл1 = ОбъединитьПути(ВремКаталог, "keep.txt");
    ЗаписьТекстаФайла = Новый ЗаписьТекста(ПутьФайл1, "UTF-8");
    ЗаписьТекстаФайла.ЗаписатьСтроку("оставить");
    ЗаписьТекстаФайла.Закрыть();

    ПутьФайл2 = ОбъединитьПути(ВремКаталог, "skip.bak");
    ЗаписьТекстаФайла = Новый ЗаписьТекста(ПутьФайл2, "UTF-8");
    ЗаписьТекстаФайла.ЗаписатьСтроку("пропустить");
    ЗаписьТекстаФайла.Закрыть();

    // Когда
    Индекс = Новый ИндексКаталога;
    Индекс.ДобавитьИсключение(".bak");
    Индекс.ПостроитьПоКаталогу(ВремКаталог);

    // Тогда
    Ожидаем.Что(Индекс.Количество(), "Только один файл без .bak").Равно(1);

    Записи = Индекс.ПолучитьЗаписи();
    Ожидаем.Что(Записи[0]).Содержит("keep.txt");
КонецПроцедуры

&Тест
Процедура ТестДолжен_ВызватьИсключениеПриНесуществующемКаталоге() Экспорт
    // Дано
    Индекс = Новый ИндексКаталога;
    ОшибкаПроизошла = Ложь;

    // Когда
    Попытка
        Индекс.ПостроитьПоКаталогу("C:\несуществующий_каталог_12345");
    Исключение
        ОшибкаПроизошла = Истина;
    КонецПопытки;

    // Тогда
    Ожидаем.Что(ОшибкаПроизошла, "Должно быть исключение").ЭтоИстина();
КонецПроцедуры

&Тест
Процедура ТестДолжен_ВызватьИсключениеПриНеверномФорматеФайла() Экспорт
    // Дано
    ПутьКФайлу = ОбъединитьПути(мКаталогВрем, "bad_format.cidx");
    ВременныеФайлы.Добавить(ПутьКФайлу);

    Запись = Новый ЗаписьТекста(ПутьКФайлу, "UTF-8");
    Запись.ЗаписатьСтроку("WRONG FORMAT");
    Запись.Закрыть();

    Индекс = Новый ИндексКаталога;
    ОшибкаПроизошла = Ложь;

    // Когда
    Попытка
        Индекс.Загрузить(ПутьКФайлу);
    Исключение
        ОшибкаПроизошла = Истина;
    КонецПопытки;

    // Тогда
    Ожидаем.Что(ОшибкаПроизошла, "Должно быть исключение при неверном формате").ЭтоИстина();
КонецПроцедуры

&Тест
Процедура ТестДолжен_РазобратьЗаписьВСтруктуру() Экспорт
    // Дано
    Индекс = Новый ИндексКаталога;
    Индекс.ПостроитьПоКаталогу(КаталогТестовыхДанных);

    Записи = Индекс.ПолучитьЗаписи();
    Ожидаем.Что(Записи.Количество()).БольшеИлиРавно(1);

    // Когда
    Структура = Индекс.РазобратьЗапись(Записи[0]);

    // Тогда
    Ожидаем.Что(Структура.Путь, "Путь заполнен").Заполнено();
    Ожидаем.Что(Структура.Размер, "Размер >= 0").БольшеИлиРавно(0);
    Ожидаем.Что(Структура.ДатаИзменения, "Дата заполнена").Заполнено();
КонецПроцедуры

&Тест
Процедура ТестДолжен_ЗаписиБытьОтсортированы() Экспорт
    // Дано
    Индекс = Новый ИндексКаталога;
    Индекс.ПостроитьПоКаталогу(КаталогТестовыхДанных);

    // Когда
    Записи = Индекс.ПолучитьЗаписи();

    // Тогда
    Для Сч = 1 По Записи.Количество() - 1 Цикл
        Ожидаем.Что(Записи[Сч] >= Записи[Сч - 1],
            "Записи должны быть отсортированы: " + Записи[Сч - 1] + " <= " + Записи[Сч]).ЭтоИстина();
    КонецЦикла;
КонецПроцедуры

&Тест
Процедура ТестДолжен_ИспользоватьПрямойСлешВПутях() Экспорт
    // Дано
    Индекс = Новый ИндексКаталога;
    Индекс.ПостроитьПоКаталогу(КаталогТестовыхДанных);

    // Тогда
    Записи = Индекс.ПолучитьЗаписи();
    Для Каждого Запись Из Записи Цикл
        Структура = Индекс.РазобратьЗапись(Запись);
        Ожидаем.Что(СтрНайти(Структура.Путь, "\") = 0,
            "Путь не должен содержать обратный слеш: " + Структура.Путь).ЭтоИстина();
    КонецЦикла;
КонецПроцедуры

Функция КаталогВременногоХранилища()
    Возврат КаталогВременныхФайлов();
КонецФункции
